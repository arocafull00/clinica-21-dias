---
import { businessId } from '../lib/seo';

interface Props {
	name: string;
	description: string;
}

const { name, description } = Astro.props;

const siteBase = Astro.site ?? new URL(Astro.url.origin);
const siteUrl = siteBase.href.replace(/\/$/, '');
const pageUrl = new URL(Astro.url.pathname, siteBase).href;

const jsonLd = [
	{
		'@context': 'https://schema.org',
		'@type': 'BreadcrumbList',
		itemListElement: [
			{
				'@type': 'ListItem',
				position: 1,
				name: 'Inicio',
				item: `${siteUrl}/`,
			},
			{
				'@type': 'ListItem',
				position: 2,
				name: 'Servicios',
				item: `${siteUrl}/#nuestros-servicios`,
			},
			{
				'@type': 'ListItem',
				position: 3,
				name,
				item: pageUrl,
			},
		],
	},
	{
		'@context': 'https://schema.org',
		'@type': 'MedicalTherapy',
		name,
		description,
		url: pageUrl,
		provider: {
			'@id': businessId(siteBase),
		},
	},
];
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
