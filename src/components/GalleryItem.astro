---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

type GalleryVariant = 'hero' | 'wide' | 'default';

interface Props {
	src: ImageMetadata;
	alt: string;
	title: string;
	index: number;
	variant: GalleryVariant;
}

const { src, alt, title, index, variant } = Astro.props;

const layoutClasses: Record<GalleryVariant, string> = {
	hero: 'col-span-2 row-span-2 min-h-[16rem] sm:min-h-[20rem]',
	wide: 'col-span-2 min-h-[11rem]',
	default: 'min-h-[11rem]',
};

const imageConfig: Record<GalleryVariant, { widths: number[]; sizes: string }> = {
	hero: {
		widths: [480, 768, 960],
		sizes: '(max-width: 640px) 100vw, 50vw',
	},
	wide: {
		widths: [480, 768, 960],
		sizes: '(max-width: 640px) 100vw, 50vw',
	},
	default: {
		widths: [320, 480, 640],
		sizes: '(max-width: 640px) 50vw, 25vw',
	},
};

const { widths, sizes } = imageConfig[variant];
---

<figure
	data-reveal
	style={`--i: ${index}`}
	class:list={[
		'relative overflow-hidden rounded-2xl border border-primary-200/40 shadow-md',
		layoutClasses[variant],
	]}
>
	<Image
		src={src}
		alt={alt}
		widths={widths}
		sizes={sizes}
		loading="lazy"
		decoding="async"
		class="absolute inset-0 h-full w-full object-cover"
	/>
	<figcaption
		class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-primary-900/80 via-primary-900/35 to-transparent px-4 py-4 md:px-5 md:py-5"
	>
		<span class="text-sm font-semibold text-white md:text-base">{title}</span>
	</figcaption>
</figure>
