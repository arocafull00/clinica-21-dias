<header
  class="fixed w-full z-50 top-0 bg-white/80 backdrop-blur-sm px-4 md:px-8 lg:px-16 xl:px-32 py-4"
>
  <nav class="flex items-center justify-between" aria-label="Principal">
    <a href="/#inicio" class="flex items-center gap-4">
      <img
        src="/flor.png"
        alt="21 días - Clínica de Psicología"
        class="h-12 w-auto rounded-full"
      />
      <span class="hidden md:block text-primary-500 text-2xl font-bold"
        >Clínica 21 Días Psicoeducación</span
      >
    </a>

    <div class="hidden md:flex space-x-8">
      <a
        href="/#inicio"
        class="relative text-gray-600 text-xl hover:text-gray-900 transition-colors after:absolute after:block after:w-full after:h-[2px] after:bottom-0 after:left-0 after:bg-primary-400 after:scale-x-0 after:origin-right after:transition-transform hover:after:scale-x-100 hover:after:origin-left"
        >Inicio</a
      >

      <a
        href="/#nuestros-servicios"
        class="relative text-gray-600 text-xl hover:text-gray-900 transition-colors after:absolute after:block after:w-full after:h-[2px] after:bottom-0 after:left-0 after:bg-primary-400 after:scale-x-0 after:origin-right after:transition-transform hover:after:scale-x-100 hover:after:origin-left"
        >Nuestros servicios</a
      >

      <a
        href="/#nuestras-instalaciones"
        class="relative text-gray-600 text-xl text-center hover:text-gray-900 transition-colors after:absolute after:block after:w-full after:h-[2px] after:bottom-0 after:left-0 after:bg-primary-400 after:scale-x-0 after:origin-right after:transition-transform hover:after:scale-x-100 hover:after:origin-left"
        >Nuestras instalaciones</a
      >

      <a
        href="/#testimonios"
        class="relative text-gray-600 text-xl hover:text-gray-900 transition-colors after:absolute after:block after:w-full after:h-[2px] after:bottom-0 after:left-0 after:bg-primary-400 after:scale-x-0 after:origin-right after:transition-transform hover:after:scale-x-100 hover:after:origin-left"
        >Testimonios</a
      >
      <a
        href="/#contacto"
        class="relative text-gray-600 text-xl hover:text-gray-900 transition-colors after:absolute after:block after:w-full after:h-[2px] after:bottom-0 after:left-0 after:bg-primary-400 after:scale-x-0 after:origin-right after:transition-transform hover:after:scale-x-100 hover:after:origin-left"
        >Contacto</a
      >
    </div>

    <button
      type="button"
      id="menu-toggle"
      class="md:hidden text-gray-600 hover:text-gray-900"
      aria-expanded="false"
      aria-controls="mobile-menu-panel"
      aria-label="Abrir menú de navegación"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-6 w-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>

    <div
      id="mobile-menu-panel"
      class="fixed inset-0 invisible opacity-0 md:hidden bg-white/95 backdrop-blur-sm z-50 transition-all duration-300 ease-in-out"
      role="dialog"
      aria-modal="true"
      aria-label="Menú principal"
      inert
    >
      <div
        class="flex flex-col items-center justify-center min-h-screen w-full space-y-8 p-4 bg-white"
      >
        <button
          type="button"
          id="close-menu"
          class="absolute top-5 right-4 text-gray-600 hover:text-gray-900 p-2"
          aria-label="Cerrar menú"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-6 w-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
        <a
          href="/#inicio"
          class="relative text-4xl text-gray-600 hover:text-gray-900 transition-colors after:absolute after:block after:w-full after:h-[2px] after:bottom-0 after:left-0 after:bg-primary-400 after:scale-x-0 after:origin-right after:transition-transform hover:after:scale-x-100 hover:after:origin-left"
          >Inicio</a
        >
        <a
          href="/#nuestros-servicios"
          class="relative text-4xl text-gray-600 hover:text-gray-900 transition-colors after:absolute after:block after:w-full after:h-[2px] after:bottom-0 after:left-0 after:bg-primary-400 after:scale-x-0 after:origin-right after:transition-transform hover:after:scale-x-100 hover:after:origin-left"
          >Nuestros servicios</a
        >
        <a
          href="/#nuestras-instalaciones"
          class="relative text-4xl text-gray-600 text-center hover:text-gray-900 transition-colors after:absolute after:block after:w-full after:h-[2px] after:bottom-0 after:left-0 after:bg-primary-400 after:scale-x-0 after:origin-right after:transition-transform hover:after:scale-x-100 hover:after:origin-left"
          >Nuestras instalaciones</a
        >
        <a
          href="/#testimonios"
          class="relative text-4xl text-gray-600 hover:text-gray-900 transition-colors after:absolute after:block after:w-full after:h-[2px] after:bottom-0 after:left-0 after:bg-primary-400 after:scale-x-0 after:origin-right after:transition-transform hover:after:scale-x-100 hover:after:origin-left"
          >Testimonios</a
        >
        <a
          href="/#contacto"
          class="relative text-4xl text-gray-600 hover:text-gray-900 transition-colors after:absolute after:block after:w-full after:h-[2px] after:bottom-0 after:left-0 after:bg-primary-400 after:scale-x-0 after:origin-right after:transition-transform hover:after:scale-x-100 hover:after:origin-left"
          >Contacto</a
        >
      </div>
    </div>
  </nav>
</header>

<script>
  const menuToggle = document.getElementById("menu-toggle");
  const closeMenuBtn = document.getElementById("close-menu");
  const mobileMenu = document.getElementById("mobile-menu-panel");
  const mobileMenuLinks = mobileMenu?.querySelectorAll("a");

  let previouslyFocused = null;
  let menuOpen = false;

  const getFocusableElements = () => {
    if (!mobileMenu) return [];
    return [
      ...mobileMenu.querySelectorAll(
        'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])',
      ),
    ];
  };

  const trapTabKey = (e) => {
    if (e.key !== "Tab" || !menuOpen) return;
    const focusables = getFocusableElements();
    if (focusables.length === 0) return;
    const first = focusables[0];
    const last = focusables[focusables.length - 1];
    if (e.shiftKey) {
      if (document.activeElement === first) {
        e.preventDefault();
        last.focus();
      }
      return;
    }
    if (document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  };

  const onEscape = (e) => {
    if (e.key === "Escape") closeMenuHandler();
  };

  const openMenu = () => {
    if (!mobileMenu || !menuToggle) return;
    previouslyFocused = document.activeElement;
    menuOpen = true;
    mobileMenu.removeAttribute("inert");
    mobileMenu.classList.remove("invisible", "opacity-0");
    mobileMenu.classList.add("opacity-100");
    document.body.style.overflow = "hidden";
    menuToggle.setAttribute("aria-expanded", "true");
    closeMenuBtn?.focus();
    document.addEventListener("keydown", onEscape);
    document.addEventListener("keydown", trapTabKey);
  };

  const closeMenuHandler = () => {
    if (!mobileMenu || !menuToggle) return;
    menuOpen = false;
    mobileMenu.classList.remove("opacity-100");
    mobileMenu.classList.add("opacity-0");
    menuToggle.setAttribute("aria-expanded", "false");
    document.removeEventListener("keydown", onEscape);
    document.removeEventListener("keydown", trapTabKey);
    setTimeout(() => {
      mobileMenu.classList.add("invisible");
      mobileMenu.setAttribute("inert", "");
      document.body.style.overflow = "";
      if (previouslyFocused instanceof HTMLElement) previouslyFocused.focus();
    }, 300);
  };

  menuToggle?.addEventListener("click", openMenu);
  closeMenuBtn?.addEventListener("click", closeMenuHandler);

  mobileMenuLinks?.forEach((link) => {
    link.addEventListener("click", closeMenuHandler);
  });
</script>
