---
const navLinks = [
  { href: "/#nuestros-servicios", label: "Servicios" },
  { href: "/#nuestras-instalaciones", label: "Instalaciones" },
  { href: "/#testimonios", label: "Testimonios" },
  { href: "/#contacto", label: "Contacto" },
];

const navLinkClass =
  "nav-link text-secondary-900 text-sm lg:text-base hover:text-primary-500 transition-colors whitespace-nowrap";
const mobileNavLinkClass =
  "mobile-menu-item text-3xl text-secondary-900 hover:text-primary-500 transition-colors";
const ctaClass =
  "btn-press inline-flex items-center justify-center text-white bg-primary-500 px-5 py-2 rounded-full text-sm lg:text-base font-semibold hover:bg-primary-600 shadow-md whitespace-nowrap";
---

<header class="site-header fixed w-full z-50 top-0 bg-white">
  <div class="px-4 md:px-8 lg:px-16 xl:px-32">
    <nav
      class="flex items-center justify-between h-16 lg:h-20 w-full"
      aria-label="Principal"
    >
      <a
        href="/#inicio"
        class="shrink-0 text-primary-500 text-lg lg:text-2xl font-bold"
      >
        21 dias psicoeducación
      </a>

      <div class="hidden md:flex items-center gap-8 xl:gap-10">
        {
          navLinks.map((link) => (
            <a href={link.href} class={navLinkClass}>
              {link.label}
            </a>
          ))
        }
      </div>

      <a href="/#contacto" class={`hidden md:inline-flex shrink-0 ${ctaClass}`}>
        Reserva Cita
      </a>

      <button
        type="button"
        id="menu-toggle"
        class="md:hidden text-secondary-900 hover:text-primary-500"
        aria-expanded="false"
        aria-controls="mobile-menu-panel"
        aria-label="Abrir menú de navegación"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </nav>
  </div>

  <div
    id="mobile-menu-panel"
    class="fixed inset-0 invisible opacity-0 md:hidden bg-white z-50 transition-all duration-300 ease-in-out"
    role="dialog"
    aria-modal="true"
    aria-label="Menú principal"
    inert
  >
    <div
      class="flex flex-col items-center justify-center min-h-screen w-full gap-8 p-4 bg-white"
    >
      <button
        type="button"
        id="close-menu"
        class="absolute top-5 right-4 text-secondary-900 hover:text-primary-500 p-2"
        aria-label="Cerrar menú"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
          </svg>
      </button>
      {
        navLinks.map((link, index) => (
          <a href={link.href} class={mobileNavLinkClass} style={`--i: ${index}`}>
            {link.label}
          </a>
        ))
      }
      <a href="/#contacto" class={`mobile-menu-item ${ctaClass} text-lg px-8 py-3`} style="--i: 4">
        Reserva Cita
      </a>
    </div>
  </div>
</header>

<script>
  const menuToggle = document.getElementById("menu-toggle");
  const closeMenuBtn = document.getElementById("close-menu");
  const mobileMenu = document.getElementById("mobile-menu-panel");
  const mobileMenuLinks = mobileMenu?.querySelectorAll("a");

  let previouslyFocused = null;
  let menuOpen = false;

  const getFocusableElements = () => {
    if (!mobileMenu) return [];
    return [
      ...mobileMenu.querySelectorAll(
        'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])',
      ),
    ];
  };

  const trapTabKey = (e) => {
    if (e.key !== "Tab" || !menuOpen) return;
    const focusables = getFocusableElements();
    if (focusables.length === 0) return;
    const first = focusables[0];
    const last = focusables[focusables.length - 1];
    if (e.shiftKey) {
      if (document.activeElement === first) {
        e.preventDefault();
        (last as HTMLElement).focus();
      }
      return;
    }
    if (document.activeElement === last) {
      e.preventDefault();
      (first as HTMLElement).focus();
    }
  };

  const onEscape = (e) => {
    if (e.key === "Escape") closeMenuHandler();
  };

  const openMenu = () => {
    if (!mobileMenu || !menuToggle) return;
    previouslyFocused = document.activeElement;
    menuOpen = true;
    mobileMenu.removeAttribute("inert");
    mobileMenu.classList.remove("invisible", "opacity-0");
    mobileMenu.classList.add("opacity-100");
    document.body.style.overflow = "hidden";
    menuToggle.setAttribute("aria-expanded", "true");
    closeMenuBtn?.focus();
    document.addEventListener("keydown", onEscape);
    document.addEventListener("keydown", trapTabKey);
  };

  const closeMenuHandler = () => {
    if (!mobileMenu || !menuToggle) return;
    menuOpen = false;
    mobileMenu.classList.remove("opacity-100");
    mobileMenu.classList.add("opacity-0");
    menuToggle.setAttribute("aria-expanded", "false");
    document.removeEventListener("keydown", onEscape);
    document.removeEventListener("keydown", trapTabKey);
    setTimeout(() => {
      mobileMenu.classList.add("invisible");
      mobileMenu.setAttribute("inert", "");
      document.body.style.overflow = "";
      if (previouslyFocused instanceof HTMLElement) previouslyFocused.focus();
    }, 300);
  };

  menuToggle?.addEventListener("click", openMenu);
  closeMenuBtn?.addEventListener("click", closeMenuHandler);

  mobileMenuLinks?.forEach((link) => {
    link.addEventListener("click", closeMenuHandler);
  });

  const header = document.querySelector(".site-header");
  const onScroll = () => {
    if (!header) return;
    header.classList.toggle("is-scrolled", window.scrollY > 8);
  };
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });
</script>
