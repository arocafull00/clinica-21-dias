---
import { Image } from "astro:assets";

const images = [
  {
    src: "/clinica/2.jpeg",
    alt: "Sala de terapia principal",
    title: "Espacio de terapia grupal",
  },
  {
    src: "/clinica/3.jpeg",
    alt: "Sala de espera",
    title: "Área de recepción",
  },
  {
    src: "/clinica/1.jpeg",
    alt: "Consultorio individual",
    title: "Sala de terapia",
  },
  {
    src: "/clinica/4.jpeg",
    alt: "Área de terapia grupal",
    title: "Entrada principal",
  },
];
---

<section class="py-20 bg-gray-50" id="nuestras-instalaciones">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl md:text-4xl font-bold text-center text-gray-800 mb-8">
      Nuestras <span class="text-primary-500">Instalaciones</span>
    </h2>
    <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
      Conoce nuestros espacios diseñados para brindarte la mayor comodidad y
      privacidad durante tu proceso terapéutico.
    </p>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      {
        images.map((image) => (
          <figure class="flex flex-col overflow-hidden rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-300">
            <Image
              height={300}
              width={300}
              src={image.src}
              alt={`${image.title}. ${image.alt}`}
              class="object-cover w-full"
            />
            <figcaption class="bg-gray-100 px-3 py-3 text-center border-t border-gray-200">
              <span class="text-lg font-semibold text-gray-800">{image.title}</span>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>
