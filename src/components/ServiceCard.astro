---
import type { AstroComponentFactory } from 'astro/runtime/server/index.js';

type ServiceVariant = 'featured' | 'wide' | 'default';

interface Props {
	icon: AstroComponentFactory;
	title: string;
	description: string;
	url: string;
	index: number;
	variant: ServiceVariant;
}

const { icon: Icon, title, description, url, index, variant } = Astro.props;

const mobileIconSize = variant === 'featured' ? 28 : 22;
const desktopIconSize = variant === 'featured' ? 48 : variant === 'wide' ? 40 : 32;

const layoutClasses: Record<ServiceVariant, string> = {
	featured:
		'flex-row items-center gap-4 p-4 md:flex-col md:items-stretch md:p-8 md:col-span-2 lg:col-span-2 lg:row-span-2 bg-gradient-to-br from-primary-50/90 via-white to-white md:min-h-[240px]',
	wide: 'flex-row items-center gap-3 p-4 md:col-span-2 md:flex-row md:items-center md:gap-8 md:p-7',
	default: 'flex-row items-center gap-3 p-4 md:flex-col md:items-stretch md:p-6',
};

const iconWrapClasses: Record<ServiceVariant, string> = {
	featured: 'shrink-0 h-12 w-12 rounded-xl bg-primary-100/70 md:mb-6 md:h-16 md:w-16 md:rounded-2xl',
	wide: 'shrink-0 h-10 w-10 rounded-xl bg-primary-50 md:h-14 md:w-14',
	default: 'shrink-0 h-10 w-10 rounded-xl bg-primary-50 md:mb-4 md:h-12 md:w-12',
};

const titleClasses: Record<ServiceVariant, string> = {
	featured: 'text-lg line-clamp-2 md:line-clamp-none md:text-2xl lg:text-3xl md:mb-4',
	wide: 'text-base line-clamp-2 md:line-clamp-none md:text-xl lg:text-2xl md:mb-3',
	default: 'text-base line-clamp-2 md:line-clamp-none md:text-lg md:mb-2',
};

const descriptionClasses: Record<ServiceVariant, string> = {
	featured: 'hidden md:block text-base lg:text-lg leading-relaxed flex-1',
	wide: 'hidden md:block text-sm md:text-base leading-relaxed',
	default: 'hidden md:block text-sm leading-relaxed line-clamp-4',
};
---

<a
	href={url}
	data-reveal
	style={`--i: ${index}`}
	class:list={[
		'card-lift group relative flex h-full cursor-pointer overflow-hidden rounded-2xl border border-primary-200/70 bg-white text-left hover:border-primary-300 hover:shadow-lg',
		layoutClasses[variant],
	]}
>
	<span
		class:list={[
			'flex items-center justify-center text-primary-500 transition-transform duration-300 group-hover:scale-110',
			iconWrapClasses[variant],
		]}
		aria-hidden="true"
	>
		<Icon size={mobileIconSize} stroke-width={1.5} class="md:hidden" />
		<Icon size={desktopIconSize} stroke-width={1.5} class="hidden md:block" />
	</span>

	<div class="flex min-w-0 flex-1 flex-col">
		<h3
			class:list={[
				'font-semibold bg-gradient-to-r from-primary-600 to-primary-400 bg-clip-text text-transparent',
				titleClasses[variant],
			]}
		>
			{title}
		</h3>
		<p class:list={['text-secondary-500', descriptionClasses[variant]]}>
			{description}
		</p>
	</div>

	<span
		class="pointer-events-none shrink-0 text-primary-400 md:absolute md:bottom-5 md:right-5 md:opacity-0 md:transition-all md:duration-300 md:group-hover:translate-x-0 md:group-hover:opacity-100 md:translate-x-1"
		aria-hidden="true"
	>
		<svg
			xmlns="http://www.w3.org/2000/svg"
			width="20"
			height="20"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
		>
			<path d="M5 12h14"></path>
			<path d="m12 5 7 7-7 7"></path>
		</svg>
	</span>
</a>
