---
import { services } from '../data/services';

const currentYear = new Date().getFullYear();
---

<footer
  class="text-gray-800 py-16 border-t border-primary-200 flex flex-col items-center justify-center gap-8 px-4"
>
  <nav aria-label="Servicios" class="w-full max-w-3xl">
    <h2 class="text-center text-lg font-semibold text-gray-800 mb-4">Servicios</h2>
    <ul class="flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm">
      {
        services.map((service) => (
          <li>
            <a
              href={service.url}
              class="text-primary-500 hover:text-primary-600 transition-colors"
            >
              {service.title}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
  <p class="text-center">
    <span class="text-primary-400">&copy; {currentYear}</span> 21 Días Psicoeducación. Clínica de Psicología. Todos los derechos reservados.
  </p>
  <a
    href="https://adrianrocafull.es/"
    target="_blank"
    rel="noopener noreferrer"
    class="text-primary-400"
  >
    Web desarrollada por <span class="font-bold">Adrian Rocafull</span>
  </a>
</footer>
