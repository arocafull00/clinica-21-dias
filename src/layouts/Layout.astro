---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Background from '../components/Background.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import RevealObserver from '../components/RevealObserver.astro';
import LocalBusinessJsonLd from '../components/LocalBusinessJsonLd.astro';
import ClientRouter from 'astro/components/ClientRouter.astro';
import {
	SITE_NAME,
	DEFAULT_OG_IMAGE,
	OG_IMAGE_WIDTH,
	OG_IMAGE_HEIGHT,
} from '../lib/seo';

interface Props {
	title: string;
	description?: string;
	siteName?: string;
	ogImage?: string;
	ogImageAlt?: string;
	ogType?: 'website' | 'article';
	noindex?: boolean;
	includeBusinessJsonLd?: boolean;
}

const defaultDescription =
	'21 días - Clínica de Psicología en Torrent. Especialistas en terapia individual, parejas y familiar.';

const {
	title,
	description = defaultDescription,
	siteName = SITE_NAME,
	ogImage = DEFAULT_OG_IMAGE,
	ogImageAlt = SITE_NAME,
	ogType = 'website',
	noindex = false,
	includeBusinessJsonLd = true,
} = Astro.props;

const siteBase = Astro.site ?? new URL(Astro.url.origin);
const canonicalURL = new URL(Astro.url.pathname, siteBase);
const ogImageAbsolute = ogImage.startsWith('http')
	? ogImage
	: new URL(ogImage.startsWith('/') ? ogImage : `/${ogImage}`, siteBase).href;
const useDefaultOgDimensions = ogImage === DEFAULT_OG_IMAGE || ogImage.endsWith('/og.jpg');
---

<!doctype html>
<html lang="es" class="bg-white scroll-smooth font-sans">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" href="/flor.png" />
		<link rel="apple-touch-icon" href="/flor.png" />
		<meta name="generator" content={Astro.generator} />
		{noindex ? (
			<meta name="robots" content="noindex, nofollow" />
		) : (
			<meta name="robots" content="index, follow, max-image-preview:large" />
		)}
		<link rel="canonical" href={canonicalURL.href} />
		<title>{title}</title>
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalURL.href} />
		<meta property="og:site_name" content={siteName} />
		<meta property="og:image" content={ogImageAbsolute} />
		<meta property="og:image:alt" content={ogImageAlt} />
		{useDefaultOgDimensions && (
			<>
				<meta property="og:image:width" content={String(OG_IMAGE_WIDTH)} />
				<meta property="og:image:height" content={String(OG_IMAGE_HEIGHT)} />
			</>
		)}
		<meta property="og:locale" content="es_ES" />
		<meta property="og:type" content={ogType} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageAbsolute} />
		<ClientRouter />
		{includeBusinessJsonLd && <LocalBusinessJsonLd />}
		<slot name="head" />
	</head>
	<body class="relative">
		<a
			href="#contenido-principal"
			class="fixed left-4 top-0 z-[100] -translate-y-full px-4 py-2 bg-primary-600 text-white rounded-lg shadow-md transition-transform focus:translate-y-4 focus:outline-none focus:ring-2 focus:ring-primary-400 focus:ring-offset-2"
		>
			Saltar al contenido
		</a>
		<Navbar />
		<slot />
		<Background />
		<WhatsAppButton />
		<RevealObserver />
	</body>
</html>
